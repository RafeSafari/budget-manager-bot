# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# OpenCode Zen API Key (get from https://opencode.ai/auth)
OPENCODE_API_KEY=

# OpenCode Zen Model (default: deepseek-v4-flash-free, which is free)
# Options: deepseek-v4-flash-free, mimo-v2.5-free, nemotron-3-ultra-free, big-pickle,
#          deepseek-v4-flash, minimax-m3, glm-5.2, kimi-k2.5, etc.
OPENCODE_MODEL=deepseek-v4-flash-free

# Database file path (default: ./data/budget.db)
DB_PATH=./data/budget.db

# Categories (comma-separated)
EXPENSE_CATEGORIES=Food,Transport,Shopping,Bills,Entertainment,Health,Education,Other
INCOME_CATEGORIES=Salary,Freelance,Gift,Refund,Other
