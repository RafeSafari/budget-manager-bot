{
  "name": "budget-manager-bot",
  "version": "2.0.0",
  "description": "Telegram bot for tracking expenses and earnings in group chats - deployed on Cloudflare Workers",
  "main": "src/index.ts",
  "scripts": {
    "setup": "node setup.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "db:create": "wrangler d1 create budget-bot-db",
    "db:migrate": "wrangler d1 migrations apply budget-bot-db"
  },
  "dependencies": {
    "date-fns": "^3.6.0",
    "grammy": "^1.21.0",
    "openai": "^4.45.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260719.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.4.0",
    "wrangler": "^4.112.0"
  }
}
