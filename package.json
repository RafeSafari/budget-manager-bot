{
  "name": "budget-manager-bot",
  "version": "2.0.0",
  "private": true,
  "description": "Telegram bot for tracking expenses and earnings — runs on Telegram Serverless",
  "scripts": {
    "deploy": "npx tgcloud push",
    "migrate": "npx tgcloud migrate",
    "status": "npx tgcloud status",
